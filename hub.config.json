{
  "version": 1,
  "log_level": "info",
  "meta_mode": true,
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/tmp"
      ],
      "tags": [
        "local"
      ],
      "disabled": false
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "tags": [
        "reasoning"
      ],
      "disabled": false
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {
        "DOCKER_CONTAINER": "true",
        "ALLOW_DANGEROUS": "true"
      },
      "tags": [
        "browser"
      ],
      "disabled": false
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY:-}"
      },
      "tags": [
        "search",
        "web"
      ],
      "disabled": false
    }
  }
}