# MCP-Hub 環境変数設定例
# このファイルを .env にコピーして編集してください

# === 基本設定 ===
# HTTP リスンポート (デフォルト: 26263)
MCP_HUB_PORT=26263

# バインドアドレス (デフォルト: 0.0.0.0)
MCP_HUB_HOST=0.0.0.0

# === 設定ファイル ===
# hub.config.json のパス (デフォルト: 自動検出 hub.config.json → ~/.config/mcp-hub/config.json)
# MCP_HUB_CONFIG=/path/to/my-hub.config.json

# === タグフィルタ ===
# 接続時に ?tags=web,local を指定する代わりにデフォルトタグを設定する場合
# MCP_HUB_DEFAULT_TAGS=web,local

# === データベース ===
# SQLite DB のパス (デフォルト: data/hub.db)
# MCP_HUB_DB_PATH=data/hub.db

# 初回起動時にDBをクリアして hub.config.json から再シード (移行用)
MCP_HUB_RESEED=1

# === ログ ===
# ログ出力形式: text (デフォルト) | json
# MCP_HUB_LOG=json
