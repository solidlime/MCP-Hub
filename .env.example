# MCP-Hub 環境変数設定例
# このファイルを .env にコピーして編集してください

# データディレクトリ（設定ファイル + DB の保存先）
#   hub.config.json → {dir}/hub.config.json
#   hub.db         → {dir}/hub.db
# デフォルト: ./data
MCP_HUB_DATA_DIR=./data

# HTTP リスンポート (デフォルト: 26263)
# MCP_HUB_PORT=26263

# バインドアドレス (デフォルト: 0.0.0.0)
# MCP_HUB_HOST=0.0.0.0

# DBをクリアして hub.config.json から再シード (移行用)
# MCP_HUB_RESEED=1

# ログ出力形式: text (デフォルト) | json
# MCP_HUB_LOG=text
